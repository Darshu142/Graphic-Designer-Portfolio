/* ── CUSTOM CURSOR ── */
(function(){
  const ring  = document.getElementById('cursor-ring');
  const dot   = document.getElementById('cursor-dot');
  const trail = document.getElementById('cursor-trail');
  const lbl   = document.getElementById('cursor-label');

  let mx=−200, my=−200;   // mouse position
  let rx=−200, ry=−200;   // ring position (lagged)
  let tx=−200, ty=−200;   // trail position (extra lagged)

  /* Track mouse */
  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    // Dot follows instantly
    dot.style.left  = mx + 'px';
    dot.style.top   = my + 'px';
    // Label sits to the right
    lbl.style.left  = (mx + 20) + 'px';
    lbl.style.top   = (my - 6)  + 'px';
  });

  /* Smooth lag loop for ring + trail */
  (function animate(){
    // Ring: medium lag
    rx += (mx - rx) * 0.1;
    ry += (my - ry) * 0.1;
    ring.style.left = rx + 'px';
    ring.style.top  = ry + 'px';

    // Trail: slower lag (ghost effect)
    tx += (mx - tx) * 0.055;
    ty += (my - ty) * 0.055;
    trail.style.left = tx + 'px';
    trail.style.top  = ty + 'px';

    requestAnimationFrame(animate);
  })();

  /* Hover states */
  const interactiveEls = document.querySelectorAll(
    'a, button, .portfolio-item, .service-card, .skill-tag, .btn-primary, .btn-ghost, .btn-send'
  );

  interactiveEls.forEach(el => {
    el.addEventListener('mouseenter', () => {
      document.body.classList.add('cur-hover');

      if (el.tagName === 'A') {
        document.body.classList.add('cur-link');
        lbl.textContent = '↗';
        lbl.style.opacity = '1';
      } else if (el.tagName === 'BUTTON') {
        document.body.classList.add('cur-link');
        lbl.textContent = 'Click';
        lbl.style.opacity = '1';
      } else if (el.classList.contains('portfolio-item')) {
        lbl.textContent = 'View';
        lbl.style.opacity = '1';
      } else if (el.classList.contains('service-card')) {
        lbl.textContent = 'Service';
        lbl.style.opacity = '1';
      }
    });

    el.addEventListener('mouseleave', () => {
      document.body.classList.remove('cur-hover', 'cur-link');
      lbl.style.opacity = '0';
    });
  });

  /* Click burst */
  document.addEventListener('mousedown', () => {
    document.body.classList.add('cur-click');
    dot.style.transform = 'translate(-50%,-50%) scale(1.8)';
  });
  document.addEventListener('mouseup', () => {
    document.body.classList.remove('cur-click');
    dot.style.transform = 'translate(-50%,-50%) scale(1)';
  });

  /* Hide cursor when leaving window */
  document.addEventListener('mouseleave', () => {
    ring.style.opacity  = '0';
    dot.style.opacity   = '0';
    trail.style.opacity = '0';
  });
  document.addEventListener('mouseenter', () => {
    ring.style.opacity  = '1';
    dot.style.opacity   = '1';
    trail.style.opacity = '1';
  });
})();